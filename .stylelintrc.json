{
  "extends": ["stylelint-config-standard-scss"],
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "tailwind",
          "apply",
          "layer",
          "config",
          "theme",
          "utility",
          "variant",
          "source",
          "plugin",
          "custom-variant"
        ]
      }
    ],
    "scss/at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "tailwind",
          "apply",
          "layer",
          "config",
          "theme",
          "utility",
          "variant",
          "source",
          "plugin",
          "custom-variant"
        ]
      }
    ],
    "alpha-value-notation": null,
    "hue-degree-notation": null,
    "lightness-notation": null
  }
}
